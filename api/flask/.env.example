# Flask
SECRET_KEY=changez_cette_cle_secrete_en_production
DEBUG=False
FLASK_ENV=production

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=woyofal_dwh
DB_USER=woyofal_user
DB_PASSWORD=changez_ce_mot_de_passe

# JWT
JWT_SECRET_KEY=changez_cette_cle_jwt_en_production

# OpenRouter (100% gratuit) — https://openrouter.ai/keys
