# ═══════════════════════════════════════════════════════════════
# Woyofal Platform - Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values

# ─── FRONTEND (React/Vite) ───────────────────────────────────────
# URL du serveur API backend
# LOCAL: http://localhost:5000/api
# PRODUCTION: https://your-railway-url/api
VITE_API_URL=http://localhost:5000/api

# ─── BACKEND (Node.js Mock Server) ────────────────────────────────
# Port d'écoute du serveur
# LOCAL: 5000
# PRODUCTION: Défini par Railway (PORT env var)
PORT=5000

# Node environment
# LOCAL: development
# PRODUCTION: production
NODE_ENV=development

# ─── OPTIONAL: Database Connection ────────────────────────────────
# Non utilisé pour le mock server, mais pour connexion réelle PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/woyofal_db

# ─── OPTIONAL: Authentication ────────────────────────────────────
# JWT Secret key (non utilisé en mock, mais pour backend réel)
# JWT_SECRET=your-super-secret-key-here

# ─── OPTIONAL: Third Party Services ──────────────────────────────
# Firebase, Auth0, Analytics, etc.
# FIREBASE_API_KEY=your-key
# AUTH0_DOMAIN=your-domain.auth0.com
